# QAOps AI configuration (all optional - sensible defaults exist)
# QAOPS_MODEL=claude-sonnet-4-6
# QAOPS_TEMPERATURE=0.2
# QAOPS_MAX_INPUT_CHARS=60000
# QAOPS_PROMPT_VERSION=v1
# QAOPS_OUTPUT_DIR=output

# Provider selection: anthropic (default) or gemini
# QAOPS_PROVIDER=anthropic
# QAOPS_GEMINI_MODEL=gemini-2.5-flash

# Required for real LLM calls. Never commit real keys.
# ANTHROPIC_API_KEY=sk-ant-...          (provider: anthropic)
# GEMINI_API_KEY=...                    (provider: gemini; needs pip install 'qaops-ai[gemini]')
