# QAOps AI configuration (optional). Place a copy named qaops.yaml in the
# directory you run `qaops` from, or pass --config <path>. Every key is
# optional and falls back to a built-in default. Environment variables
# (QAOPS_*) override any value set here.

# LLM provider: anthropic (default) or gemini
provider: anthropic

# Model per provider
model: claude-sonnet-4-6
gemini_model: gemini-2.5-flash

# Generation controls
temperature: 0.2
max_output_tokens: 8000
llm_retries: 2

# Input guardrail: requests larger than this (characters) are rejected
max_input_chars: 60000

# Prompt template version
prompt_version: v1

# Where reports are written, and which formats by default
output_dir: output
# Formats: markdown, json, csv (single test-case table), xlsx,
# csv-bundle (six CSVs: Requirements/BusinessRules/Scenarios/TestCases/GapAnalysis/Coverage)
default_export_formats: [markdown, json]

# Chunking (ADR-020, ADR-021). 'adaptive' (default) sizes chunks from the
# provider/model's practical output capacity and skips chunking entirely
# for documents that fit - no tuning needed. Use 'fixed' only to override.
chunking_strategy: adaptive
chunk_safety_margin: 0.8
# Used ONLY when chunking_strategy is 'fixed':
# chunk_size: 8000
# chunk_overlap: 500

# TEMPORARY evaluation mode (ADR-019). Off by default. No longer required
# for large documents now that chunking exists.
# Large documents can generate more structured JSON than a model can return in
# one response. When enabled, the analyzer asks the model for at most
# max_requirements requirements and enforces that cap in code, so the whole
# pipeline completes on a real PRD. This analyzes only part of a large
# document - it is a demonstration aid, not a scaling solution. It will be
# removed when document chunking lands.
# evaluation_mode: true
# max_requirements: 10
